<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{review.title}}</title>
    <style>
      :root {
        color-scheme: light;
        /* openknowledge design DNA tokens */
        --bg: #fbf9f4;
        --surface: #fcfcfa;
        --card: #ffffff;
        --ink: #1a1a1a;
        --ink-strong: #231f20;
        --muted: #71717a;
        --muted-fill: #f0ece3;
        --line: #e4e3e0;
        --line-strong: #d4d4d0;
        --dot: #c4c8cc;
        --primary: #3784ff;
        --primary-strong: #1b60f5;
        --warn-fill: #ffefd9;
        --warn-line: #fcdfb6;
        --warn-ink: #9a5b00;
        --ok: #009767;
        --ok-fill: #e2f5ee;
        --risk: #fb2c36;
        --code-bg: #231f20;
        --code-ink: #f0f0ee;
        --sticky-bg: rgb(251 249 244 / 72%);
        --shadow-hairline: 0 1px 2px rgba(15, 23, 42, 0.05);
        --shadow-toolbar: 0 1px 2px rgba(15, 23, 42, 0.04), 0 2px 6px -2px rgba(15, 23, 42, 0.06);
        --shadow-panel: 0 18px 48px -24px rgba(35, 31, 32, 0.18);
        --shadow-window: 0 0 48px -16px rgba(35, 31, 32, 0.18);
        --ease: cubic-bezier(0.4, 0, 0.2, 1);
        --font-sans: "DM Sans", Inter, ui-sans-serif, system-ui, -apple-system,
          BlinkMacSystemFont, "Segoe UI", sans-serif;
        --font-mono: "JetBrains Mono", "SFMono-Regular", "SF Mono", Menlo, Consolas,
          "Liberation Mono", monospace;
      }

      /* Dark palette. Keep the two blocks below identical: one covers the explicit
         "Dark" choice, the other covers "System" (no data-theme) on a dark OS. */
      :root[data-theme="dark"] {
        color-scheme: dark;
        --bg: #171614;
        --surface: #1e1d1b;
        --card: #211f1d;
        --ink: #e6e4df;
        --ink-strong: #f2f1ee;
        --muted: #a3a3ab;
        --muted-fill: #2e2c28;
        --line: #34322e;
        --line-strong: #4a4741;
        --dot: #3d3a34;
        --primary: #6ea3ff;
        --primary-strong: #8db8ff;
        --warn-fill: #382a13;
        --warn-line: #57431f;
        --warn-ink: #f0b45c;
        --ok: #3ecf9a;
        --ok-fill: #14352a;
        --risk: #ff6b6e;
        --code-bg: #1a1918;
        --sticky-bg: rgb(23 22 20 / 72%);
        --shadow-hairline: 0 1px 2px rgba(0, 0, 0, 0.4);
        --shadow-toolbar: 0 1px 2px rgba(0, 0, 0, 0.35), 0 2px 6px -2px rgba(0, 0, 0, 0.4);
        --shadow-panel: 0 18px 48px -24px rgba(0, 0, 0, 0.6);
        --shadow-window: 0 0 48px -16px rgba(0, 0, 0, 0.6);
      }

      @media (prefers-color-scheme: dark) {
        :root:not([data-theme="light"]) {
          color-scheme: dark;
          --bg: #171614;
          --surface: #1e1d1b;
          --card: #211f1d;
          --ink: #e6e4df;
          --ink-strong: #f2f1ee;
          --muted: #a3a3ab;
          --muted-fill: #2e2c28;
          --line: #34322e;
          --line-strong: #4a4741;
          --dot: #3d3a34;
          --primary: #6ea3ff;
          --primary-strong: #8db8ff;
          --warn-fill: #382a13;
          --warn-line: #57431f;
          --warn-ink: #f0b45c;
          --ok: #3ecf9a;
          --ok-fill: #14352a;
          --risk: #ff6b6e;
          --code-bg: #1a1918;
          --sticky-bg: rgb(23 22 20 / 72%);
          --shadow-hairline: 0 1px 2px rgba(0, 0, 0, 0.4);
          --shadow-toolbar: 0 1px 2px rgba(0, 0, 0, 0.35), 0 2px 6px -2px rgba(0, 0, 0, 0.4);
          --shadow-panel: 0 18px 48px -24px rgba(0, 0, 0, 0.6);
          --shadow-window: 0 0 48px -16px rgba(0, 0, 0, 0.6);
        }
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background-color: var(--bg);
        background-image: radial-gradient(var(--dot) 1px, transparent 1px);
        background-size: 24px 24px;
        color: var(--ink);
        font: 16px/1.55 var(--font-sans);
        -webkit-font-smoothing: antialiased;
      }

      ::selection {
        background: rgba(55, 132, 255, 0.2);
      }

      a {
        color: var(--primary-strong);
        text-decoration-thickness: 1px;
        text-underline-offset: 3px;
      }

      .hamburger,
      .drawer-scrim {
        display: none;
      }

      .page {
        max-width: 1180px;
        margin: 0 auto;
        padding: 48px 20px 72px;
      }

      .sticky-title {
        position: fixed;
        inset: 0 0 auto;
        z-index: 15;
        border-bottom: 1px solid var(--line);
        background: var(--sticky-bg);
        opacity: 0;
        pointer-events: none;
        transform: translateY(-100%);
        visibility: hidden;
        -webkit-backdrop-filter: blur(20px) saturate(140%);
        backdrop-filter: blur(20px) saturate(140%);
        box-shadow: var(--shadow-toolbar);
      }

      body.title-stuck .sticky-title {
        opacity: 1;
        transform: translateY(0);
        visibility: visible;
        pointer-events: auto;
        cursor: pointer;
      }

      .back-to-top {
        position: fixed;
        right: 20px;
        bottom: 20px;
        z-index: 15;
        display: grid;
        place-items: center;
        width: 44px;
        height: 44px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: var(--card);
        padding: 0;
        color: var(--ink);
        box-shadow: var(--shadow-toolbar);
        cursor: pointer;
        opacity: 0;
        transform: translateY(8px);
        visibility: hidden;
      }

      .back-to-top svg {
        width: 18px;
        height: 18px;
      }

      .back-to-top:hover {
        box-shadow: var(--shadow-panel);
      }

      .back-to-top:focus-visible {
        outline: 2px solid var(--primary);
        outline-offset: 2px;
      }

      body.title-stuck .back-to-top {
        opacity: 1;
        transform: translateY(0);
        visibility: visible;
      }

      .sticky-title__inner {
        display: flex;
        align-items: center;
        width: min(1180px, 100%);
        min-height: 48px;
        margin: 0 auto;
        padding: 0 128px 0 20px;
        overflow: hidden;
        font-size: 14px;
        font-weight: 500;
        line-height: 1.35;
      }

      .sticky-title__inner > span {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      header.hero {
        display: grid;
        gap: 20px;
        border-bottom: 1px solid var(--line);
        padding-bottom: 28px;
      }

      .eyebrow {
        margin: 0 0 14px;
        color: var(--muted);
        font-size: 13px;
        font-weight: 500;
      }

      h1,
      h2,
      h3 {
        line-height: 1.15;
        letter-spacing: -0.025em;
        text-wrap: balance;
      }

      h1 {
        max-width: 820px;
        margin: 0;
        font-size: clamp(26px, 3.5vw, 40px);
        font-weight: 300;
        line-height: 1.1;
      }

      h1 code,
      h2 code {
        font-size: 0.9em;
      }

      h2 {
        margin: 0 0 16px;
        font-size: 20px;
        font-weight: 400;
      }

      /* Section titles stay pinned below the sticky title bar while their card scrolls */
      section > h2 {
        position: sticky;
        top: 48px;
        z-index: 2;
        display: flex;
        align-items: center;
        gap: 10px;
        margin: -28px -28px 4px;
        border-radius: 16px 16px 0 0;
        background: var(--card);
        padding: 20px 28px 12px;
      }

      section > h2 svg {
        flex: none;
        width: 18px;
        height: 18px;
        color: var(--muted);
      }

      h3 {
        margin: 0 0 8px;
        font-size: 17px;
        font-weight: 500;
        letter-spacing: -0.01em;
      }

      p {
        margin: 0;
      }

      .lede {
        max-width: 720px;
        margin-top: 14px;
        color: var(--muted);
        font-size: 16px;
      }

      /* Facts strip: one Phosphor icon + value per PR fact, scannable left to right */
      .meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 10px 26px;
      }

      .meta .fact {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 15px;
        font-weight: 500;
        font-variant-numeric: tabular-nums;
      }

      .meta .fact svg {
        flex: none;
        width: 17px;
        height: 17px;
        color: var(--muted);
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        margin: -1px;
        overflow: hidden;
        clip-path: inset(50%);
        white-space: nowrap;
      }

      .diff-add {
        color: var(--ok);
      }

      .diff-del {
        color: var(--risk);
      }

      main {
        display: grid;
        grid-template-columns: 220px minmax(0, 1fr);
        gap: 32px;
        margin-top: 36px;
      }

      nav {
        position: sticky;
        top: 72px;
        align-self: start;
        padding: 6px 0;
      }

      nav a {
        display: block;
        border-radius: 999px;
        padding: 8px 14px;
        color: var(--muted);
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        transition: color 150ms var(--ease), background-color 150ms var(--ease);
      }

      nav a:hover {
        color: var(--ink);
        background: var(--muted-fill);
      }

      nav a:focus-visible {
        outline: 2px solid var(--primary);
        outline-offset: 2px;
      }

      .content {
        display: grid;
        gap: 22px;
        min-width: 0;
      }

      section {
        min-width: 0;
        scroll-margin-top: 72px;
        border: 1px solid var(--line);
        border-radius: 16px;
        background: var(--card);
        padding: 28px;
        box-shadow: var(--shadow-hairline);
      }

      .callout {
        border: 1px solid var(--warn-line);
        border-radius: 12px;
        background: var(--warn-fill);
        padding: 20px 22px;
      }

      .grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 18px;
      }

      .mini {
        min-width: 0;
        border-top: 1px solid var(--line);
        padding-top: 18px;
      }

      .mini:first-child {
        border-top: 0;
        padding-top: 0;
      }

      .mini h3 {
        margin-top: 10px;
      }

      .ref {
        color: var(--muted);
        font-family: var(--font-mono);
        font-size: 12px;
      }

      .mini p,
      li {
        color: var(--muted);
      }

      .mini > p {
        margin-top: 12px;
        color: var(--muted);
      }

      ul,
      ol {
        margin: 10px 0 0;
        padding-left: 22px;
      }

      li + li {
        margin-top: 8px;
      }

      .reading-list {
        counter-reset: step;
        display: grid;
        gap: 14px;
        margin-top: 16px;
      }

      .reading-item {
        display: grid;
        grid-template-columns: 24px minmax(0, 1fr);
        gap: 12px;
        align-items: start;
      }

      .reading-item h3 {
        display: inline-flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 2px 6px;
      }

      .reading-item::before {
        counter-increment: step;
        content: counter(step) ".";
        color: var(--muted);
        font-family: var(--font-mono);
        font-size: 14px;
        /* Match the file-link's first line box (13px text / 16px icon) so the
           number sits on the same visual line as the link. */
        line-height: 20px;
        text-align: right;
      }

      .reading-item > * {
        min-width: 0;
      }

      code {
        border-radius: 6px;
        background: var(--muted-fill);
        padding: 2px 6px;
        color: var(--ink-strong);
        font-family: var(--font-mono);
        font-size: 0.86em;
      }

      .claim-table {
        display: grid;
        gap: 12px;
        margin-top: 14px;
      }

      .footer-note {
        color: var(--muted);
        font-size: 14px;
      }

      @media (prefers-reduced-motion: no-preference) {
        .sticky-title,
        .back-to-top {
          transition: opacity 150ms var(--ease), transform 150ms var(--ease),
            visibility 150ms var(--ease), box-shadow 150ms var(--ease);
        }

        section {
          animation: reveal-in 500ms var(--ease) backwards;
        }

        section:nth-child(2) { animation-delay: 60ms; }
        section:nth-child(3) { animation-delay: 120ms; }
        section:nth-child(4) { animation-delay: 180ms; }

        @keyframes reveal-in {
          from {
            opacity: 0;
            transform: translateY(7px);
          }
          to {
            opacity: 1;
            transform: none;
          }
        }
      }

      @media (max-width: 860px) {
        header.hero,
        main {
          grid-template-columns: 1fr;
        }

        .page {
          padding-top: 84px;
        }

        .sticky-title__inner {
          padding-left: 76px;
        }

        .hamburger {
          position: fixed;
          top: 16px;
          left: 16px;
          z-index: 35;
          display: inline-flex;
          width: 44px;
          height: 44px;
          flex-direction: column;
          justify-content: center;
          gap: 5px;
          border: 1px solid var(--line);
          border-radius: 999px;
          background: var(--card);
          box-shadow: var(--shadow-panel);
          cursor: pointer;
          transition: transform 150ms var(--ease), box-shadow 150ms var(--ease);
        }

        .hamburger:hover {
          transform: translateY(-2px);
        }

        .hamburger:active {
          transform: scale(0.98);
        }

        .hamburger span {
          display: block;
          width: 18px;
          height: 2px;
          margin: 0 auto;
          border-radius: 999px;
          background: var(--ink);
        }

        .drawer-scrim {
          position: fixed;
          inset: 0;
          z-index: 20;
          border: 0;
          background: rgba(35, 31, 32, 0.35);
          padding: 0;
        }

        body.drawer-open .drawer-scrim {
          display: block;
        }

        main {
          display: block;
        }

        nav {
          position: fixed;
          top: 0;
          bottom: 0;
          left: 0;
          z-index: 30;
          width: min(82vw, 320px);
          border-right: 1px solid var(--line);
          background: var(--card);
          padding: 84px 22px 22px;
          transform: translateX(-105%);
          transition: transform 200ms var(--ease);
          visibility: hidden;
          box-shadow: var(--shadow-window);
        }

        body.drawer-open nav {
          transform: translateX(0);
          visibility: visible;
        }

        nav a {
          padding: 12px 14px;
          font-size: 16px;
        }

      }
    </style>
    {{> component-scripts}}
  </head>
  <body>
    {{> theme-switch}}
    <button
      class="hamburger"
      type="button"
      aria-controls="report-nav"
      aria-expanded="false"
      aria-label="Open report menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
    <button class="drawer-scrim" type="button" aria-label="Close report menu"></button>
    <div class="sticky-title" aria-hidden="true">
      <div class="sticky-title__inner"><span>{{review.title}}</span></div>
    </div>
    <button class="back-to-top" type="button" aria-label="Back to top" title="Back to top">
      <svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M200,112H56l72-72Z" opacity="0.2"/><path d="M205.66,106.34l-72-72a8,8,0,0,0-11.32,0l-72,72A8,8,0,0,0,56,120h64v96a8,8,0,0,0,16,0V120h64a8,8,0,0,0,5.66-13.66ZM75.31,104,128,51.31,180.69,104Z"/></svg>
    </button>
    <div class="page">
      <header class="hero">
        <div>
          <p class="eyebrow">Guided Review</p>
          <h1>{{review.title}}</h1>
        </div>
        <aside class="meta" aria-label="Pull request metadata">
          <span class="fact">
            <svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M208,72V184a8,8,0,0,1-8,8H176V104L136,64H80V40a8,8,0,0,1,8-8h80Z" opacity="0.2"/><path d="M213.66,66.34l-40-40A8,8,0,0,0,168,24H88A16,16,0,0,0,72,40V56H56A16,16,0,0,0,40,72V216a16,16,0,0,0,16,16H168a16,16,0,0,0,16-16V200h16a16,16,0,0,0,16-16V72A8,8,0,0,0,213.66,66.34ZM168,216H56V72h76.69L168,107.31v84.53c0,.06,0,.11,0,.16s0,.1,0,.16V216Zm32-32H184V104a8,8,0,0,0-2.34-5.66l-40-40A8,8,0,0,0,136,56H88V40h76.69L200,75.31Zm-56-32a8,8,0,0,1-8,8H88a8,8,0,0,1,0-16h48A8,8,0,0,1,144,152Zm0,32a8,8,0,0,1-8,8H88a8,8,0,0,1,0-16h48A8,8,0,0,1,144,184Z"/></svg>
            <span class="sr-only">Files</span>
            <span>{{review.metadata.files}}</span>
          </span>
          <span class="fact">
            <svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M80,64A24,24,0,1,1,56,40,24,24,0,0,1,80,64ZM200,168a24,24,0,1,0,24,24A24,24,0,0,0,200,168Z" opacity="0.2"/><path d="M112,152a8,8,0,0,0-8,8v28.69L66.34,151A8,8,0,0,1,64,145.37V95a32,32,0,1,0-16,0v50.38a23.85,23.85,0,0,0,7,17L92.69,200H64a8,8,0,0,0,0,16h48a8,8,0,0,0,8-8V160A8,8,0,0,0,112,152ZM40,64A16,16,0,1,1,56,80,16,16,0,0,1,40,64Zm168,97V110.63a23.85,23.85,0,0,0-7-17L163.31,56H192a8,8,0,0,0,0-16H144a8,8,0,0,0-8,8V96a8,8,0,0,0,16,0V67.31L189.66,105a8,8,0,0,1,2.34,5.66V161a32,32,0,1,0,16,0Zm-8,47a16,16,0,1,1,16-16A16,16,0,0,1,200,208Z"/></svg>
            <span class="sr-only">Diff</span>
            <span>
              <span class="diff-add">{{review.metadata.additions}}</span> /
              <span class="diff-del">{{review.metadata.deletions}}</span>
            </span>
          </span>
          <span class="fact">
            <svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M208,216H48a8,8,0,0,1-6.86-12.12l30.48-50.8h0c13.23-2.48,32-1.41,56.37,10.92,32.25,16.33,54.75,12.91,67.5,7.65h0l19.34,32.23A8,8,0,0,1,208,216Z" opacity="0.2"/><path d="M221.69,199.77,160,96.92V40h8a8,8,0,0,0,0-16H88a8,8,0,0,0,0,16h8V96.92L34.31,199.77A16,16,0,0,0,48,224H208a16,16,0,0,0,13.72-24.23ZM110.86,103.25A7.93,7.93,0,0,0,112,99.14V40h32V99.14a7.93,7.93,0,0,0,1.14,4.11L183.36,167c-12,2.37-29.07,1.37-51.75-10.11-15.91-8.05-31.05-12.32-45.22-12.81ZM48,208l28.54-47.58c14.25-1.74,30.31,1.85,47.82,10.72,19,9.61,35,12.88,48,12.88a69.89,69.89,0,0,0,19.55-2.7L208,208Z"/></svg>
            <span class="sr-only">Tests</span>
            <span>{{review.metadata.tests}}</span>
          </span>
          <span class="fact">
            <svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M104,56A24,24,0,1,1,80,32,24,24,0,0,1,104,56Z" opacity="0.2"/><path d="M208,112a32.05,32.05,0,0,0-30.69,23l-42.21-6a8,8,0,0,1-4.95-2.71L94.43,84.55A32,32,0,1,0,72,87v82a32,32,0,1,0,16,0V101.63l30,35a24,24,0,0,0,14.83,8.14l44,6.28A32,32,0,1,0,208,112ZM64,56A16,16,0,1,1,80,72,16,16,0,0,1,64,56ZM96,200a16,16,0,1,1-16-16A16,16,0,0,1,96,200Zm112-40a16,16,0,1,1,16-16A16,16,0,0,1,208,160Z"/></svg>
            <span class="sr-only">Merge</span>
            <span>{{review.metadata.merge}}</span>
          </span>
          <span class="fact">
