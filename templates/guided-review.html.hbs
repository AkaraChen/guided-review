<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{review.title}}</title>
    <style>
      :root {
        color-scheme: light;
        /* openknowledge design DNA tokens */
        --bg: #fbf9f4;
        --surface: #fcfcfa;
        --card: #ffffff;
        --ink: #1a1a1a;
        --ink-strong: #231f20;
        --muted: #71717a;
        --muted-fill: #f0ece3;
        --line: #e4e3e0;
        --line-strong: #d4d4d0;
        --dot: #c4c8cc;
        --primary: #3784ff;
        --primary-strong: #1b60f5;
        --accent: #d5e5ff;
        --accent-ink: #29325c;
        --warn-fill: #ffefd9;
        --warn-line: #fcdfb6;
        --warn-ink: #9a5b00;
        --ok: #009767;
        --ok-fill: #e2f5ee;
        --risk: #fb2c36;
        --code-bg: #231f20;
        --code-ink: #f0f0ee;
        --sticky-bg: rgb(251 249 244 / 72%);
        --shadow-hairline: 0 1px 2px rgba(15, 23, 42, 0.05);
        --shadow-toolbar: 0 1px 2px rgba(15, 23, 42, 0.04), 0 2px 6px -2px rgba(15, 23, 42, 0.06);
        --shadow-panel: 0 18px 48px -24px rgba(35, 31, 32, 0.18);
        --shadow-window: 0 0 48px -16px rgba(35, 31, 32, 0.18);
        --ease: cubic-bezier(0.4, 0, 0.2, 1);
        --font-sans: "DM Sans", Inter, ui-sans-serif, system-ui, -apple-system,
          BlinkMacSystemFont, "Segoe UI", sans-serif;
        --font-mono: "JetBrains Mono", "SFMono-Regular", "SF Mono", Menlo, Consolas,
          "Liberation Mono", monospace;
      }

      /* Dark palette. Keep the two blocks below identical: one covers the explicit
         "Dark" choice, the other covers "System" (no data-theme) on a dark OS. */
      :root[data-theme="dark"] {
        color-scheme: dark;
        --bg: #171614;
        --surface: #1e1d1b;
        --card: #211f1d;
        --ink: #e6e4df;
        --ink-strong: #f2f1ee;
        --muted: #a3a3ab;
        --muted-fill: #2e2c28;
        --line: #34322e;
        --line-strong: #4a4741;
        --dot: #262421;
        --primary: #6ea3ff;
        --primary-strong: #8db8ff;
        --accent: #263450;
        --accent-ink: #c8d9ff;
        --warn-fill: #382a13;
        --warn-line: #57431f;
        --warn-ink: #f0b45c;
        --ok: #3ecf9a;
        --ok-fill: #14352a;
        --risk: #ff6b6e;
        --code-bg: #1a1918;
        --sticky-bg: rgb(23 22 20 / 72%);
        --shadow-hairline: 0 1px 2px rgba(0, 0, 0, 0.4);
        --shadow-toolbar: 0 1px 2px rgba(0, 0, 0, 0.35), 0 2px 6px -2px rgba(0, 0, 0, 0.4);
        --shadow-panel: 0 18px 48px -24px rgba(0, 0, 0, 0.6);
        --shadow-window: 0 0 48px -16px rgba(0, 0, 0, 0.6);
      }

      @media (prefers-color-scheme: dark) {
        :root:not([data-theme="light"]) {
          color-scheme: dark;
          --bg: #171614;
          --surface: #1e1d1b;
          --card: #211f1d;
          --ink: #e6e4df;
          --ink-strong: #f2f1ee;
          --muted: #a3a3ab;
          --muted-fill: #2e2c28;
          --line: #34322e;
          --line-strong: #4a4741;
          --dot: #262421;
          --primary: #6ea3ff;
          --primary-strong: #8db8ff;
          --accent: #263450;
          --accent-ink: #c8d9ff;
          --warn-fill: #382a13;
          --warn-line: #57431f;
          --warn-ink: #f0b45c;
          --ok: #3ecf9a;
          --ok-fill: #14352a;
          --risk: #ff6b6e;
          --code-bg: #1a1918;
          --sticky-bg: rgb(23 22 20 / 72%);
          --shadow-hairline: 0 1px 2px rgba(0, 0, 0, 0.4);
          --shadow-toolbar: 0 1px 2px rgba(0, 0, 0, 0.35), 0 2px 6px -2px rgba(0, 0, 0, 0.4);
          --shadow-panel: 0 18px 48px -24px rgba(0, 0, 0, 0.6);
          --shadow-window: 0 0 48px -16px rgba(0, 0, 0, 0.6);
        }
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background-color: var(--bg);
        background-image: radial-gradient(var(--dot) 1px, transparent 1px);
        background-size: 24px 24px;
        color: var(--ink);
        font: 16px/1.55 var(--font-sans);
        -webkit-font-smoothing: antialiased;
      }

      ::selection {
        background: rgba(55, 132, 255, 0.2);
      }

      a {
        color: var(--primary-strong);
        text-decoration-thickness: 1px;
        text-underline-offset: 3px;
      }

      .hamburger,
      .drawer-scrim {
        display: none;
      }

      .theme-switch {
        position: fixed;
        /* Vertically centered in the 48px sticky title bar: (48px - 36px pill) / 2 */
        top: 6px;
        right: 16px;
        z-index: 40;
        display: inline-flex;
        gap: 2px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: var(--card);
        padding: 3px;
        box-shadow: var(--shadow-toolbar);
      }

      .theme-switch button {
        display: grid;
        place-items: center;
        width: 28px;
        height: 28px;
        border: 0;
        border-radius: 999px;
        background: transparent;
        padding: 0;
        color: var(--muted);
        cursor: pointer;
        transition: color 150ms var(--ease), background-color 150ms var(--ease);
      }

      .theme-switch button svg {
        width: 15px;
        height: 15px;
      }

      .theme-switch button:hover {
        color: var(--ink);
      }

      .theme-switch button:focus-visible {
        outline: 2px solid var(--primary);
        outline-offset: 1px;
      }

      .theme-switch button[aria-pressed="true"] {
        background: var(--muted-fill);
        color: var(--ink);
      }

      .page {
        max-width: 1180px;
        margin: 0 auto;
        padding: 48px 20px 72px;
      }

      .sticky-title {
        position: fixed;
        inset: 0 0 auto;
        z-index: 15;
        border-bottom: 1px solid var(--line);
        background: var(--sticky-bg);
        opacity: 0;
        pointer-events: none;
        transform: translateY(-100%);
        visibility: hidden;
        -webkit-backdrop-filter: blur(20px) saturate(140%);
        backdrop-filter: blur(20px) saturate(140%);
        box-shadow: var(--shadow-toolbar);
      }

      body.title-stuck .sticky-title {
        opacity: 1;
        transform: translateY(0);
        visibility: visible;
      }

      .sticky-title__inner {
        display: flex;
        align-items: center;
        width: min(1180px, 100%);
        min-height: 48px;
        margin: 0 auto;
        padding: 0 128px 0 20px;
        overflow: hidden;
        font-size: 14px;
        font-weight: 500;
        line-height: 1.35;
      }

      .sticky-title__inner > span {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      header.hero {
        display: grid;
        gap: 20px;
        border-bottom: 1px solid var(--line);
        padding-bottom: 28px;
      }

      .eyebrow {
        margin: 0 0 14px;
        color: var(--primary);
        font-family: var(--font-mono);
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      h1,
      h2,
      h3 {
        line-height: 1.15;
        letter-spacing: -0.025em;
        text-wrap: balance;
      }

      h1 {
        max-width: 820px;
        margin: 0;
        font-size: clamp(26px, 3.5vw, 40px);
        font-weight: 300;
        line-height: 1.1;
      }

      h1 code,
      h2 code {
        font-size: 0.9em;
      }

      h2 {
        margin: 0 0 16px;
        font-size: 26px;
        font-weight: 300;
      }

      /* Section titles stay pinned below the sticky title bar while their card scrolls */
      section > h2 {
        position: sticky;
        top: 48px;
        z-index: 2;
        margin: -28px -28px 4px;
        border-radius: 16px 16px 0 0;
        background: var(--card);
        padding: 20px 28px 12px;
      }

      h3 {
        margin: 0 0 8px;
        font-size: 17px;
        font-weight: 500;
        letter-spacing: -0.01em;
      }

      p {
        margin: 0;
      }

      .lede {
        max-width: 720px;
        margin-top: 14px;
        color: var(--muted);
        font-size: 16px;
      }

      /* Facts strip: one Phosphor icon + value per PR fact, scannable left to right */
      .meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 10px 26px;
      }

      .meta .fact {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 15px;
        font-weight: 500;
        font-variant-numeric: tabular-nums;
      }

      .meta .fact svg {
        flex: none;
        width: 17px;
        height: 17px;
        color: var(--muted);
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        margin: -1px;
        overflow: hidden;
        clip-path: inset(50%);
        white-space: nowrap;
      }

      .diff-add {
        color: var(--ok);
      }

      .diff-del {
        color: var(--risk);
      }

      main {
        display: grid;
        grid-template-columns: 220px minmax(0, 1fr);
        gap: 32px;
        margin-top: 36px;
      }

      nav {
        position: sticky;
        top: 72px;
        align-self: start;
        padding: 6px 0;
      }

      nav a {
        display: block;
        border-radius: 999px;
        padding: 8px 14px;
        color: var(--muted);
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        transition: color 150ms var(--ease), background-color 150ms var(--ease);
      }

      nav a:hover {
        color: var(--ink);
        background: var(--muted-fill);
      }

      nav a:focus-visible {
        outline: 2px solid var(--primary);
        outline-offset: 2px;
      }

      .content {
        display: grid;
        gap: 22px;
        min-width: 0;
      }

      section {
        min-width: 0;
        scroll-margin-top: 72px;
        border: 1px solid var(--line);
        border-radius: 16px;
        background: var(--card);
        padding: 28px;
        box-shadow: var(--shadow-hairline);
      }

      .callout {
        border: 1px solid var(--warn-line);
        border-radius: 12px;
        background: var(--warn-fill);
        padding: 20px 22px;
      }

      .grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 18px;
      }

      .mini {
        min-width: 0;
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 20px;
        background: var(--surface);
      }

      .mini h3 {
        margin-top: 12px;
      }

      .mini p,
      li {
        color: var(--muted);
      }

      .mini > p,
      .risk-row > p {
        margin-top: 12px;
        color: var(--muted);
      }

      ul,
      ol {
        margin: 10px 0 0;
        padding-left: 22px;
      }

      li + li {
        margin-top: 8px;
      }

      .tag {
        display: inline-flex;
        align-items: center;
        min-height: 26px;
        border-radius: 999px;
        background: var(--accent);
        color: var(--accent-ink);
        padding: 2px 12px;
        font-family: var(--font-mono);
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .tag.warn {
        background: var(--warn-fill);
        color: var(--warn-ink);
      }

      .tag.ok {
        background: var(--ok-fill);
        color: var(--ok);
      }

      .reading-list {
        counter-reset: step;
        display: grid;
        gap: 14px;
        margin-top: 16px;
      }

      .reading-item {
        display: grid;
        grid-template-columns: 44px minmax(0, 1fr);
        gap: 14px;
        align-items: start;
        border-top: 1px solid var(--line);
        padding-top: 14px;
      }

      .reading-item:first-child {
        border-top: 0;
        padding-top: 0;
      }

      .reading-item::before {
        counter-increment: step;
        content: counter(step);
        display: grid;
        place-items: center;
        width: 34px;
        height: 34px;
        border-radius: 999px;
        background: var(--primary);
        color: #ffffff;
        font-family: var(--font-mono);
        font-size: 14px;
        font-weight: 500;
      }

      .reading-item > *,
      .risk-row > * {
        min-width: 0;
      }

      .line-link {
        margin-top: 8px;
        font-size: 14px;
        font-weight: 500;
      }

      code {
        border-radius: 6px;
        background: var(--muted-fill);
        padding: 2px 6px;
        color: var(--ink-strong);
        font-family: var(--font-mono);
        font-size: 0.86em;
      }

      .risk-table {
        display: grid;
        gap: 12px;
        margin-top: 14px;
      }

      .risk-row {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
        border-top: 1px solid var(--line);
        padding-top: 16px;
      }

      /* Code evidence styled as an openknowledge product window */
      .code-card {
        border: 1px solid var(--line-strong);
        border-radius: 12px;
        background: var(--code-bg);
        color: var(--code-ink);
        margin-top: 14px;
        overflow: hidden;
        box-shadow: var(--shadow-window);
      }

      .code-card header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 16px;
        border-bottom: 1px solid rgba(240, 240, 238, 0.12);
        padding: 12px 14px;
      }

      .code-card h3 {
        min-width: 0;
        margin: 0;
        color: var(--code-ink);
        font-size: 13.5px;
        font-weight: 500;
        letter-spacing: 0;
      }

      .code-card a {
        min-width: 0;
        max-width: 65%;
        color: #8ec6ff;
        font-family: var(--font-mono);
        font-size: 12px;
        font-weight: 500;
        overflow-wrap: anywhere;
        text-align: right;
      }

      .code-card pre {
        margin: 0;
        overflow-x: auto;
        padding: 12px 0;
        font: 12px/1.6 var(--font-mono);
      }

      .code-line {
        display: grid;
        grid-template-columns: 46px minmax(max-content, 1fr);
        gap: 12px;
        padding: 0 14px;
      }

      .ln {
        color: rgba(240, 240, 238, 0.4);
        font-variant-numeric: tabular-nums;
        text-align: right;
        user-select: none;
      }

      .src {
        white-space: pre;
      }

      /* shiki enhancement: token colors come from inline styles; keep our window chrome */
      .code-card pre.is-highlighted .src {
        color: #dbd7cf;
      }

      .footer-note {
        color: var(--muted);
        font-size: 14px;
      }

      @media (prefers-reduced-motion: no-preference) {
        .sticky-title {
          transition: opacity 150ms var(--ease), transform 150ms var(--ease),
            visibility 150ms var(--ease);
        }

        section {
          animation: reveal-in 500ms var(--ease) backwards;
        }

        section:nth-child(2) { animation-delay: 60ms; }
        section:nth-child(3) { animation-delay: 120ms; }
        section:nth-child(4) { animation-delay: 180ms; }

        @keyframes reveal-in {
          from {
            opacity: 0;
            transform: translateY(7px);
          }
          to {
            opacity: 1;
            transform: none;
          }
        }
      }

      @media (max-width: 860px) {
        header.hero,
        main {
          grid-template-columns: 1fr;
        }

        .page {
          padding-top: 84px;
        }

        .sticky-title__inner {
          padding-left: 76px;
        }

        .hamburger {
          position: fixed;
          top: 16px;
          left: 16px;
          z-index: 35;
          display: inline-flex;
          width: 44px;
          height: 44px;
          flex-direction: column;
          justify-content: center;
          gap: 5px;
          border: 1px solid var(--line);
          border-radius: 999px;
          background: var(--card);
          box-shadow: var(--shadow-panel);
          cursor: pointer;
          transition: transform 150ms var(--ease), box-shadow 150ms var(--ease);
        }

        .hamburger:hover {
          transform: translateY(-2px);
        }

        .hamburger:active {
          transform: scale(0.98);
        }

        .hamburger span {
          display: block;
          width: 18px;
          height: 2px;
          margin: 0 auto;
          border-radius: 999px;
          background: var(--ink);
        }

        .drawer-scrim {
          position: fixed;
          inset: 0;
          z-index: 20;
          border: 0;
          background: rgba(35, 31, 32, 0.35);
          padding: 0;
        }

        body.drawer-open .drawer-scrim {
          display: block;
        }

        main {
          display: block;
        }

        nav {
          position: fixed;
          top: 0;
          bottom: 0;
          left: 0;
          z-index: 30;
          width: min(82vw, 320px);
          border-right: 1px solid var(--line);
          background: var(--card);
          padding: 84px 22px 22px;
          transform: translateX(-105%);
          transition: transform 200ms var(--ease);
          visibility: hidden;
          box-shadow: var(--shadow-window);
        }

        body.drawer-open nav {
          transform: translateX(0);
          visibility: visible;
        }

        nav a {
          padding: 12px 14px;
          font-size: 16px;
        }

      }
    </style>
    <script>
      // Apply a saved theme before first paint to avoid a flash; "system" stores nothing.
      try {
        const savedTheme = localStorage.getItem("theme");
        if (savedTheme === "light" || savedTheme === "dark") {
          document.documentElement.dataset.theme = savedTheme;
        }
      } catch {
        /* no storage access: stay on system theme */
      }
    </script>
  </head>
  <body>
    <button
      class="hamburger"
      type="button"
      aria-controls="report-nav"
      aria-expanded="false"
      aria-label="Open report menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
    <button class="drawer-scrim" type="button" aria-label="Close report menu"></button>
    <div class="theme-switch" role="group" aria-label="Color theme">
      <button type="button" data-set-theme="system" aria-pressed="true" aria-label="System theme" title="System theme">
        <svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M224,64V176a16,16,0,0,1-16,16H48a16,16,0,0,1-16-16V64A16,16,0,0,1,48,48H208A16,16,0,0,1,224,64Z" opacity="0.2"/><path d="M208,40H48A24,24,0,0,0,24,64V176a24,24,0,0,0,24,24H208a24,24,0,0,0,24-24V64A24,24,0,0,0,208,40Zm8,136a8,8,0,0,1-8,8H48a8,8,0,0,1-8-8V64a8,8,0,0,1,8-8H208a8,8,0,0,1,8,8Zm-48,48a8,8,0,0,1-8,8H96a8,8,0,0,1,0-16h64A8,8,0,0,1,168,224Z"/></svg>
      </button>
      <button type="button" data-set-theme="light" aria-pressed="false" aria-label="Light theme" title="Light theme">
        <svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M184,128a56,56,0,1,1-56-56A56,56,0,0,1,184,128Z" opacity="0.2"/><path d="M120,40V16a8,8,0,0,1,16,0V40a8,8,0,0,1-16,0Zm72,88a64,64,0,1,1-64-64A64.07,64.07,0,0,1,192,128Zm-16,0a48,48,0,1,0-48,48A48.05,48.05,0,0,0,176,128ZM58.34,69.66A8,8,0,0,0,69.66,58.34l-16-16A8,8,0,0,0,42.34,53.66Zm0,116.68-16,16a8,8,0,0,0,11.32,11.32l16-16a8,8,0,0,0-11.32-11.32ZM192,72a8,8,0,0,0,5.66-2.34l16-16a8,8,0,0,0-11.32-11.32l-16,16A8,8,0,0,0,192,72Zm5.66,114.34a8,8,0,0,0-11.32,11.32l16,16a8,8,0,0,0,11.32-11.32ZM48,128a8,8,0,0,0-8-8H16a8,8,0,0,0,0,16H40A8,8,0,0,0,48,128Zm80,80a8,8,0,0,0-8,8v24a8,8,0,0,0,16,0V216A8,8,0,0,0,128,208Zm112-88H216a8,8,0,0,0,0,16h24a8,8,0,0,0,0-16Z"/></svg>
      </button>
      <button type="button" data-set-theme="dark" aria-pressed="false" aria-label="Dark theme" title="Dark theme">
        <svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M227.89,147.89A96,96,0,1,1,108.11,28.11,96.09,96.09,0,0,0,227.89,147.89Z" opacity="0.2"/><path d="M233.54,142.23a8,8,0,0,0-8-2,88.08,88.08,0,0,1-109.8-109.8,8,8,0,0,0-10-10,104.84,104.84,0,0,0-52.91,37A104,104,0,0,0,136,224a103.09,103.09,0,0,0,62.52-20.88,104.84,104.84,0,0,0,37-52.91A8,8,0,0,0,233.54,142.23ZM188.9,190.34A88,88,0,0,1,65.66,67.11a89,89,0,0,1,31.4-26A106,106,0,0,0,96,56,104.11,104.11,0,0,0,200,160a106,106,0,0,0,14.92-1.06A89,89,0,0,1,188.9,190.34Z"/></svg>
      </button>
    </div>
    <div class="sticky-title" aria-hidden="true">
      <div class="sticky-title__inner"><span>{{review.title}}</span></div>
    </div>
    <div class="page">
      <header class="hero">
        <div>
          <p class="eyebrow">Guided Review</p>
          <h1>{{review.title}}</h1>
        </div>
        <aside class="meta" aria-label="Pull request metadata">
          <span class="fact">
            <svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M208,72V184a8,8,0,0,1-8,8H176V104L136,64H80V40a8,8,0,0,1,8-8h80Z" opacity="0.2"/><path d="M213.66,66.34l-40-40A8,8,0,0,0,168,24H88A16,16,0,0,0,72,40V56H56A16,16,0,0,0,40,72V216a16,16,0,0,0,16,16H168a16,16,0,0,0,16-16V200h16a16,16,0,0,0,16-16V72A8,8,0,0,0,213.66,66.34ZM168,216H56V72h76.69L168,107.31v84.53c0,.06,0,.11,0,.16s0,.1,0,.16V216Zm32-32H184V104a8,8,0,0,0-2.34-5.66l-40-40A8,8,0,0,0,136,56H88V40h76.69L200,75.31Zm-56-32a8,8,0,0,1-8,8H88a8,8,0,0,1,0-16h48A8,8,0,0,1,144,152Zm0,32a8,8,0,0,1-8,8H88a8,8,0,0,1,0-16h48A8,8,0,0,1,144,184Z"/></svg>
            <span class="sr-only">Files</span>
            <span>{{review.metadata.files}}</span>
          </span>
          <span class="fact">
            <svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M80,64A24,24,0,1,1,56,40,24,24,0,0,1,80,64ZM200,168a24,24,0,1,0,24,24A24,24,0,0,0,200,168Z" opacity="0.2"/><path d="M112,152a8,8,0,0,0-8,8v28.69L66.34,151A8,8,0,0,1,64,145.37V95a32,32,0,1,0-16,0v50.38a23.85,23.85,0,0,0,7,17L92.69,200H64a8,8,0,0,0,0,16h48a8,8,0,0,0,8-8V160A8,8,0,0,0,112,152ZM40,64A16,16,0,1,1,56,80,16,16,0,0,1,40,64Zm168,97V110.63a23.85,23.85,0,0,0-7-17L163.31,56H192a8,8,0,0,0,0-16H144a8,8,0,0,0-8,8V96a8,8,0,0,0,16,0V67.31L189.66,105a8,8,0,0,1,2.34,5.66V161a32,32,0,1,0,16,0Zm-8,47a16,16,0,1,1,16-16A16,16,0,0,1,200,208Z"/></svg>
            <span class="sr-only">Diff</span>
            <span>
              <span class="diff-add">{{review.metadata.additions}}</span> /
              <span class="diff-del">{{review.metadata.deletions}}</span>
            </span>
          </span>
          <span class="fact">
            <svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M208,216H48a8,8,0,0,1-6.86-12.12l30.48-50.8h0c13.23-2.48,32-1.41,56.37,10.92,32.25,16.33,54.75,12.91,67.5,7.65h0l19.34,32.23A8,8,0,0,1,208,216Z" opacity="0.2"/><path d="M221.69,199.77,160,96.92V40h8a8,8,0,0,0,0-16H88a8,8,0,0,0,0,16h8V96.92L34.31,199.77A16,16,0,0,0,48,224H208a16,16,0,0,0,13.72-24.23ZM110.86,103.25A7.93,7.93,0,0,0,112,99.14V40h32V99.14a7.93,7.93,0,0,0,1.14,4.11L183.36,167c-12,2.37-29.07,1.37-51.75-10.11-15.91-8.05-31.05-12.32-45.22-12.81ZM48,208l28.54-47.58c14.25-1.74,30.31,1.85,47.82,10.72,19,9.61,35,12.88,48,12.88a69.89,69.89,0,0,0,19.55-2.7L208,208Z"/></svg>
            <span class="sr-only">Tests</span>
            <span>{{review.metadata.tests}}</span>
          </span>
          <span class="fact">
            <svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M104,56A24,24,0,1,1,80,32,24,24,0,0,1,104,56Z" opacity="0.2"/><path d="M208,112a32.05,32.05,0,0,0-30.69,23l-42.21-6a8,8,0,0,1-4.95-2.71L94.43,84.55A32,32,0,1,0,72,87v82a32,32,0,1,0,16,0V101.63l30,35a24,24,0,0,0,14.83,8.14l44,6.28A32,32,0,1,0,208,112ZM64,56A16,16,0,1,1,80,72,16,16,0,0,1,64,56ZM96,200a16,16,0,1,1-16-16A16,16,0,0,1,96,200Zm112-40a16,16,0,1,1,16-16A16,16,0,0,1,208,160Z"/></svg>
            <span class="sr-only">Merge</span>
            <span>{{review.metadata.merge}}</span>
          </span>
          <span class="fact">
            <svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M128,56C48,56,16,128,16,128s32,72,112,72,112-72,112-72S208,56,128,56Zm0,112a40,40,0,1,1,40-40A40,40,0,0,1,128,168Z" opacity="0.2"/><path d="M247.31,124.76c-.35-.79-8.82-19.58-27.65-38.41C194.57,61.26,162.88,48,128,48S61.43,61.26,36.34,86.35C17.51,105.18,9,124,8.69,124.76a8,8,0,0,0,0,6.5c.35.79,8.82,19.57,27.65,38.4C61.43,194.74,93.12,208,128,208s66.57-13.26,91.66-38.34c18.83-18.83,27.3-37.61,27.65-38.4A8,8,0,0,0,247.31,124.76ZM128,192c-30.78,0-57.67-11.19-79.93-33.25A133.47,133.47,0,0,1,25,128,133.33,133.33,0,0,1,48.07,97.25C70.33,75.19,97.22,64,128,64s57.67,11.19,79.93,33.25A133.46,133.46,0,0,1,231.05,128C223.84,141.46,192.43,192,128,192Zm0-112a48,48,0,1,0,48,48A48.05,48.05,0,0,0,128,80Zm0,80a32,32,0,1,1,32-32A32,32,0,0,1,128,160Z"/></svg>
            <span class="sr-only">Review</span>
            <span>{{review.recommendation.decision}}</span>
          </span>
        </aside>
      </header>

      <main>
        <nav id="report-nav" aria-label="Report sections">
          <a href="#thesis">Thesis</a>
          <a href="#reading">Reading order</a>
          <a href="#lines">Evidence</a>
          <a href="#verification">Verification</a>
          <a href="#risks">Risks</a>
          <a href="#questions">Questions</a>
          <a href="#recommendation">Recommendation</a>
        </nav>

        <div class="content">
          <section id="thesis">
            <h2>Thesis</h2>
            <p>{{review.thesis.text}}</p>
            {{> evidence review.thesis}}
          </section>

          <section id="reading">
            <h2>Suggested Reading Order</h2>
            <div class="reading-list">
              {{#each review.reading_order}}
              <div class="reading-item">
                <div>
                  <h3><code>{{path}}</code></h3>
                  <p>{{reason.text}}</p>
                </div>
              </div>
              {{/each}}
            </div>
          </section>

          <section id="lines">
            <h2>Evidence Walkthrough</h2>
            <div class="grid">
              {{#each review.line_map}}
              <article class="mini">
                <span class="tag">{{line}}</span>
                <span class="tag">{{claim.basis}}</span>
                <h3>{{claim.text}}</h3>
                {{> evidence claim}}
              </article>
              {{/each}}
            </div>
          </section>

          <section id="verification">
            <h2>Verification Focus</h2>
            <div class="risk-table">
              {{#each review.verification}}
              <div class="risk-row">
                <strong><span class="tag">{{status}}</span></strong>
                {{> evidence claim}}
                <p>{{claim.text}}</p>
              </div>
              {{/each}}
            </div>
          </section>

          <section id="risks">
            <h2>Key Risks</h2>
            {{#if review.risks}}
            <div class="risk-table">
              {{#each review.risks}}
              <div class="risk-row">
                <strong><span class="tag warn">{{level}}</span></strong>
                {{> evidence claim}}
                <p>{{claim.text}}</p>
              </div>
              {{/each}}
            </div>
            {{else}}
            <div class="callout">
              <p>No risk entries were supplied.</p>
            </div>
            {{/if}}
          </section>

          <section id="questions">
            <h2>Questions For The Author</h2>
            {{#if review.questions}}
            <ul>
              {{#each review.questions}}
              <li>
                <p>{{text}}</p>
                {{> evidence this}}
              </li>
              {{/each}}
            </ul>
            {{else}}
            <p>No author questions were supplied.</p>
            {{/if}}
          </section>

          <section id="recommendation">
            <h2>Review Recommendation</h2>
            <div class="callout">
              <p>
                <strong>{{review.recommendation.decision}}.</strong>
                {{review.recommendation.summary.text}}
              </p>
            </div>
            {{> evidence review.recommendation.summary}}

            {{#if review.recommendation.blockers}}
            <div class="risk-table">
              {{#each review.recommendation.blockers}}
              <div class="risk-row">
                <strong><span class="tag warn">Blocker</span></strong>
                {{> evidence this}}
                <p>{{text}}</p>
              </div>
              {{/each}}
            </div>
            {{/if}}

            {{#if review.recommendation.follow_ups}}
            <div class="risk-table">
              {{#each review.recommendation.follow_ups}}
              <div class="risk-row">
                <strong><span class="tag">Follow-up</span></strong>
                {{> evidence this}}
                <p>{{text}}</p>
              </div>
              {{/each}}
            </div>
            {{/if}}
          </section>

        </div>
      </main>
    </div>
    <script>
      const menuButton = document.querySelector(".hamburger");
      const drawerScrim = document.querySelector(".drawer-scrim");
      const heroTitle = document.querySelector(".hero h1");
      const stickyTitle = document.querySelector(".sticky-title");
      const setMenuOpen = (isOpen) => {
        document.body.classList.toggle("drawer-open", isOpen);
        menuButton.setAttribute("aria-expanded", String(isOpen));
      };

      menuButton.addEventListener("click", () => {
        setMenuOpen(!document.body.classList.contains("drawer-open"));
      });

      drawerScrim.addEventListener("click", () => {
        setMenuOpen(false);
      });

      document.querySelectorAll("#report-nav a").forEach((link) => {
        link.addEventListener("click", () => {
          setMenuOpen(false);
        });
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") setMenuOpen(false);
      });

      const themeButtons = document.querySelectorAll(".theme-switch button");
      const applyThemePreference = (preference) => {
        if (preference === "light" || preference === "dark") {
          document.documentElement.dataset.theme = preference;
        } else {
          delete document.documentElement.dataset.theme;
        }
        themeButtons.forEach((button) => {
          button.setAttribute("aria-pressed", String(button.dataset.setTheme === preference));
        });
        try {
          if (preference === "system") localStorage.removeItem("theme");
          else localStorage.setItem("theme", preference);
        } catch {
          /* no storage access: theme still applies for this page view */
        }
      };

      themeButtons.forEach((button) => {
        button.addEventListener("click", () => applyThemePreference(button.dataset.setTheme));
      });

      applyThemePreference(document.documentElement.dataset.theme ?? "system");

      if (heroTitle && stickyTitle) {
        const titleObserver = new IntersectionObserver(([entry]) => {
          const titleIsAboveViewport = !entry.isIntersecting && entry.boundingClientRect.bottom <= 0;
          document.body.classList.toggle("title-stuck", titleIsAboveViewport);
        });
        titleObserver.observe(heroTitle);
      }
    </script>
    <script type="module">
      // Progressive enhancement: highlight evidence blocks with shiki (CDN).
      // On failure (offline, CDN blocked) the plain rendering above remains.
      try {
        const { codeToHtml } = await import("https://esm.sh/shiki@3.0.0");
        const parser = new DOMParser();
        for (const pre of document.querySelectorAll(".code-card pre")) {
          const rows = [...pre.querySelectorAll(".code-line")];
          if (rows.length === 0) continue;
          const code = rows.map((row) => row.querySelector(".src").textContent).join("\n");
          const lang = pre.dataset.lang === "md" ? "markdown" : "typescript";
          const highlighted = await codeToHtml(code, { lang, theme: "vitesse-dark" });
          const lines = parser
            .parseFromString(highlighted, "text/html")
            .querySelectorAll("code .line");
          if (lines.length !== rows.length) continue;
          rows.forEach((row, index) => {
            row.querySelector(".src").innerHTML = lines[index].innerHTML;
          });
          pre.classList.add("is-highlighted");
        }
      } catch {
        /* keep unhighlighted fallback */
      }
    </script>
  </body>
</html>
