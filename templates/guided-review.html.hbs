<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{review.title}}</title>
    <style>
      :root {
        color-scheme: light;
        /* openknowledge design DNA tokens */
        --bg: #fbf9f4;
        --surface: #fcfcfa;
        --card: #ffffff;
        --ink: #1a1a1a;
        --ink-strong: #231f20;
        --muted: #71717a;
        --muted-fill: #f0ece3;
        --line: #e4e3e0;
        --line-strong: #d4d4d0;
        --dot: #c4c8cc;
        --primary: #3784ff;
        --primary-strong: #1b60f5;
        --accent: #d5e5ff;
        --accent-ink: #29325c;
        --warn-fill: #ffefd9;
        --warn-line: #fcdfb6;
        --warn-ink: #9a5b00;
        --ok: #009767;
        --ok-fill: #e2f5ee;
        --risk: #fb2c36;
        --code-bg: #231f20;
        --code-ink: #f0f0ee;
        --shadow-hairline: 0 1px 2px rgba(15, 23, 42, 0.05);
        --shadow-toolbar: 0 1px 2px rgba(15, 23, 42, 0.04), 0 2px 6px -2px rgba(15, 23, 42, 0.06);
        --shadow-panel: 0 18px 48px -24px rgba(35, 31, 32, 0.18);
        --shadow-window: 0 0 48px -16px rgba(35, 31, 32, 0.18);
        --ease: cubic-bezier(0.4, 0, 0.2, 1);
        --font-sans: "DM Sans", Inter, ui-sans-serif, system-ui, -apple-system,
          BlinkMacSystemFont, "Segoe UI", sans-serif;
        --font-mono: "JetBrains Mono", "SFMono-Regular", "SF Mono", Menlo, Consolas,
          "Liberation Mono", monospace;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background-color: var(--bg);
        background-image: radial-gradient(var(--dot) 1px, transparent 1px);
        background-size: 24px 24px;
        color: var(--ink);
        font: 16px/1.55 var(--font-sans);
        -webkit-font-smoothing: antialiased;
      }

      ::selection {
        background: rgba(55, 132, 255, 0.2);
      }

      a {
        color: var(--primary-strong);
        text-decoration-thickness: 1px;
        text-underline-offset: 3px;
      }

      .hamburger,
      .drawer-scrim {
        display: none;
      }

      .page {
        max-width: 1180px;
        margin: 0 auto;
        padding: 48px 20px 72px;
      }

      .sticky-title {
        position: fixed;
        inset: 0 0 auto;
        z-index: 15;
        border-bottom: 1px solid var(--line);
        background: rgb(251 249 244 / 72%);
        opacity: 0;
        pointer-events: none;
        transform: translateY(-100%);
        visibility: hidden;
        -webkit-backdrop-filter: blur(20px) saturate(140%);
        backdrop-filter: blur(20px) saturate(140%);
        box-shadow: var(--shadow-toolbar);
      }

      body.title-stuck .sticky-title {
        opacity: 1;
        transform: translateY(0);
        visibility: visible;
      }

      .sticky-title__inner {
        width: min(1180px, 100%);
        margin: 0 auto;
        padding: 14px 20px;
        overflow: hidden;
        font-size: 14px;
        font-weight: 500;
        line-height: 1.35;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      header.hero {
        display: grid;
        gap: 28px;
        border-bottom: 1px solid var(--line);
        padding-bottom: 36px;
      }

      .eyebrow {
        margin: 0 0 14px;
        color: var(--primary);
        font-family: var(--font-mono);
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      h1,
      h2,
      h3 {
        line-height: 1.15;
        letter-spacing: -0.025em;
        text-wrap: balance;
      }

      h1 {
        max-width: 820px;
        margin: 0;
        font-size: clamp(34px, 5vw, 60px);
        font-weight: 300;
        line-height: 1.1;
      }

      h1 code,
      h2 code {
        font-size: 0.9em;
      }

      h2 {
        margin: 0 0 16px;
        font-size: 26px;
        font-weight: 300;
      }

      h3 {
        margin: 0 0 8px;
        font-size: 17px;
        font-weight: 500;
        letter-spacing: -0.01em;
      }

      p {
        margin: 0;
      }

      .lede {
        max-width: 720px;
        margin-top: 20px;
        color: var(--muted);
        font-size: 18px;
      }

      /* Facts strip: one labeled cell per PR fact, scannable left to right */
      .meta {
        border: 1px solid var(--line);
        border-radius: 16px;
        background: var(--card);
        box-shadow: var(--shadow-hairline);
        overflow: hidden;
      }

      .meta dl {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        margin: 0;
      }

      .meta .fact {
        display: grid;
        gap: 6px;
        align-content: start;
        border-left: 1px solid var(--line);
        padding: 16px 20px;
      }

      .meta .fact:first-child {
        border-left: 0;
      }

      .meta dt {
        color: var(--muted);
        font-family: var(--font-mono);
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .meta dd {
        margin: 0;
        font-weight: 500;
        font-size: 15px;
        font-variant-numeric: tabular-nums;
      }

      .diff-add {
        color: var(--ok);
      }

      .diff-del {
        color: var(--risk);
      }

      main {
        display: grid;
        grid-template-columns: 220px minmax(0, 1fr);
        gap: 32px;
        margin-top: 36px;
      }

      nav {
        position: sticky;
        top: 72px;
        align-self: start;
        padding: 6px 0;
      }

      nav a {
        display: block;
        border-radius: 999px;
        padding: 8px 14px;
        color: var(--muted);
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        transition: color 150ms var(--ease), background-color 150ms var(--ease);
      }

      nav a:hover {
        color: var(--ink);
        background: var(--muted-fill);
      }

      nav a:focus-visible {
        outline: 2px solid var(--primary);
        outline-offset: 2px;
      }

      .content {
        display: grid;
        gap: 22px;
        min-width: 0;
      }

      section {
        min-width: 0;
        scroll-margin-top: 72px;
        border: 1px solid var(--line);
        border-radius: 16px;
        background: var(--card);
        padding: 28px;
        box-shadow: var(--shadow-hairline);
      }

      .callout {
        border: 1px solid var(--warn-line);
        border-radius: 12px;
        background: var(--warn-fill);
        padding: 20px 22px;
      }

      .grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 18px;
      }

      .mini {
        min-width: 0;
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 20px;
        background: var(--surface);
      }

      .mini h3 {
        margin-top: 12px;
      }

      .mini p,
      li {
        color: var(--muted);
      }

      .mini > p,
      .risk-row > p {
        margin-top: 12px;
        color: var(--muted);
      }

      ul,
      ol {
        margin: 10px 0 0;
        padding-left: 22px;
      }

      li + li {
        margin-top: 8px;
      }

      .tag {
        display: inline-flex;
        align-items: center;
        min-height: 26px;
        border-radius: 999px;
        background: var(--accent);
        color: var(--accent-ink);
        padding: 2px 12px;
        font-family: var(--font-mono);
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .tag.warn {
        background: var(--warn-fill);
        color: var(--warn-ink);
      }

      .tag.ok {
        background: var(--ok-fill);
        color: var(--ok);
      }

      .reading-list {
        counter-reset: step;
        display: grid;
        gap: 14px;
        margin-top: 16px;
      }

      .reading-item {
        display: grid;
        grid-template-columns: 44px minmax(0, 1fr);
        gap: 14px;
        align-items: start;
        border-top: 1px solid var(--line);
        padding-top: 14px;
      }

      .reading-item:first-child {
        border-top: 0;
        padding-top: 0;
      }

      .reading-item::before {
        counter-increment: step;
        content: counter(step);
        display: grid;
        place-items: center;
        width: 34px;
        height: 34px;
        border-radius: 999px;
        background: var(--primary);
        color: #ffffff;
        font-family: var(--font-mono);
        font-size: 14px;
        font-weight: 500;
      }

      .reading-item > *,
      .risk-row > * {
        min-width: 0;
      }

      .line-link {
        margin-top: 8px;
        font-size: 14px;
        font-weight: 500;
      }

      code {
        border-radius: 6px;
        background: var(--muted-fill);
        padding: 2px 6px;
        color: var(--ink-strong);
        font-family: var(--font-mono);
        font-size: 0.86em;
      }

      .risk-table {
        display: grid;
        gap: 12px;
        margin-top: 14px;
      }

      .risk-row {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
        border-top: 1px solid var(--line);
        padding-top: 16px;
      }

      /* Code evidence styled as an openknowledge product window */
      .code-card {
        border: 1px solid var(--line-strong);
        border-radius: 12px;
        background: var(--code-bg);
        color: var(--code-ink);
        margin-top: 14px;
        overflow: hidden;
        box-shadow: var(--shadow-window);
      }

      .code-card header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 16px;
        border-bottom: 1px solid rgba(240, 240, 238, 0.12);
        padding: 12px 14px;
      }

      .code-card h3 {
        min-width: 0;
        margin: 0;
        color: var(--code-ink);
        font-size: 13.5px;
        font-weight: 500;
        letter-spacing: 0;
      }

      .code-card a {
        min-width: 0;
        max-width: 65%;
        color: #8ec6ff;
        font-family: var(--font-mono);
        font-size: 12px;
        font-weight: 500;
        overflow-wrap: anywhere;
        text-align: right;
      }

      .code-card pre {
        margin: 0;
        overflow-x: auto;
        padding: 12px 0;
        font: 12px/1.6 var(--font-mono);
      }

      .code-line {
        display: grid;
        grid-template-columns: 46px minmax(max-content, 1fr);
        gap: 12px;
        padding: 0 14px;
      }

      .ln {
        color: rgba(240, 240, 238, 0.4);
        font-variant-numeric: tabular-nums;
        text-align: right;
        user-select: none;
      }

      .src {
        white-space: pre;
      }

      /* shiki enhancement: token colors come from inline styles; keep our window chrome */
      .code-card pre.is-highlighted .src {
        color: #dbd7cf;
      }

      .footer-note {
        color: var(--muted);
        font-size: 14px;
      }

      @media (prefers-reduced-motion: no-preference) {
        .sticky-title {
          transition: opacity 150ms var(--ease), transform 150ms var(--ease),
            visibility 150ms var(--ease);
        }

        section {
          animation: reveal-in 500ms var(--ease) backwards;
        }

        section:nth-child(2) { animation-delay: 60ms; }
        section:nth-child(3) { animation-delay: 120ms; }
        section:nth-child(4) { animation-delay: 180ms; }

        @keyframes reveal-in {
          from {
            opacity: 0;
            transform: translateY(7px);
          }
          to {
            opacity: 1;
            transform: none;
          }
        }
      }

      @media (max-width: 860px) {
        header.hero,
        main {
          grid-template-columns: 1fr;
        }

        .page {
          padding-top: 84px;
        }

        .sticky-title__inner {
          padding-left: 76px;
        }

        .hamburger {
          position: fixed;
          top: 16px;
          left: 16px;
          z-index: 35;
          display: inline-flex;
          width: 44px;
          height: 44px;
          flex-direction: column;
          justify-content: center;
          gap: 5px;
          border: 1px solid var(--line);
          border-radius: 999px;
          background: var(--card);
          box-shadow: var(--shadow-panel);
          cursor: pointer;
          transition: transform 150ms var(--ease), box-shadow 150ms var(--ease);
        }

        .hamburger:hover {
          transform: translateY(-2px);
        }

        .hamburger:active {
          transform: scale(0.98);
        }

        .hamburger span {
          display: block;
          width: 18px;
          height: 2px;
          margin: 0 auto;
          border-radius: 999px;
          background: var(--ink);
        }

        .drawer-scrim {
          position: fixed;
          inset: 0;
          z-index: 20;
          border: 0;
          background: rgba(35, 31, 32, 0.35);
          padding: 0;
        }

        body.drawer-open .drawer-scrim {
          display: block;
        }

        main {
          display: block;
        }

        nav {
          position: fixed;
          top: 0;
          bottom: 0;
          left: 0;
          z-index: 30;
          width: min(82vw, 320px);
          border-right: 1px solid var(--line);
          background: var(--card);
          padding: 84px 22px 22px;
          transform: translateX(-105%);
          transition: transform 200ms var(--ease);
          visibility: hidden;
          box-shadow: var(--shadow-window);
        }

        body.drawer-open nav {
          transform: translateX(0);
          visibility: visible;
        }

        nav a {
          padding: 12px 14px;
          font-size: 16px;
        }

        .meta .fact {
          border-left: 0;
          border-top: 1px solid var(--line);
        }

        .meta .fact:first-child {
          border-top: 0;
        }
      }
    </style>
  </head>
  <body>
    <button
      class="hamburger"
      type="button"
      aria-controls="report-nav"
      aria-expanded="false"
      aria-label="Open report menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
    <button class="drawer-scrim" type="button" aria-label="Close report menu"></button>
    <div class="sticky-title" aria-hidden="true">
      <div class="sticky-title__inner">{{review.title}}</div>
    </div>
    <div class="page">
      <header class="hero">
        <div>
          <p class="eyebrow">Guided Review</p>
          <h1>{{review.title}}</h1>
        </div>
        <aside class="meta" aria-label="Pull request metadata">
          <dl>
            <div class="fact">
              <dt>Files</dt>
              <dd>{{review.metadata.files}}</dd>
            </div>
            <div class="fact">
              <dt>Diff</dt>
              <dd>
                <span class="diff-add">{{review.metadata.additions}}</span> /
                <span class="diff-del">{{review.metadata.deletions}}</span>
              </dd>
            </div>
            <div class="fact">
              <dt>Tests</dt>
              <dd>{{review.metadata.tests}}</dd>
            </div>
            <div class="fact">
              <dt>Merge</dt>
              <dd>{{review.metadata.merge}}</dd>
            </div>
            <div class="fact">
              <dt>Review</dt>
              <dd class="diff-del">{{review.recommendation.decision}}</dd>
            </div>
          </dl>
        </aside>
      </header>

      <main>
        <nav id="report-nav" aria-label="Report sections">
          <a href="#thesis">Thesis</a>
          <a href="#reading">Reading order</a>
          <a href="#lines">Evidence</a>
          <a href="#verification">Verification</a>
          <a href="#risks">Risks</a>
          <a href="#questions">Questions</a>
          <a href="#recommendation">Recommendation</a>
        </nav>

        <div class="content">
          <section id="thesis">
            <h2>Thesis</h2>
            <p>{{review.thesis.text}}</p>
            {{> evidence review.thesis}}
          </section>

          <section id="reading">
            <h2>Suggested Reading Order</h2>
            <div class="reading-list">
              {{#each review.reading_order}}
              <div class="reading-item">
                <div>
                  <h3><code>{{path}}</code></h3>
                  <p>{{reason.text}}</p>
                </div>
              </div>
              {{/each}}
            </div>
          </section>

          <section id="lines">
            <h2>Evidence Walkthrough</h2>
            <div class="grid">
              {{#each review.line_map}}
              <article class="mini">
                <span class="tag">{{line}}</span>
                <span class="tag">{{claim.basis}}</span>
                <h3>{{claim.text}}</h3>
                {{> evidence claim}}
              </article>
              {{/each}}
            </div>
          </section>

          <section id="verification">
            <h2>Verification Focus</h2>
            <div class="risk-table">
              {{#each review.verification}}
              <div class="risk-row">
                <strong><span class="tag">{{status}}</span></strong>
                {{> evidence claim}}
                <p>{{claim.text}}</p>
              </div>
              {{/each}}
            </div>
          </section>

          <section id="risks">
            <h2>Key Risks</h2>
            {{#if review.risks}}
            <div class="risk-table">
              {{#each review.risks}}
              <div class="risk-row">
                <strong><span class="tag warn">{{level}}</span></strong>
                {{> evidence claim}}
                <p>{{claim.text}}</p>
              </div>
              {{/each}}
            </div>
            {{else}}
            <div class="callout">
              <p>No risk entries were supplied.</p>
            </div>
            {{/if}}
          </section>

          <section id="questions">
            <h2>Questions For The Author</h2>
            {{#if review.questions}}
            <ul>
              {{#each review.questions}}
              <li>
                <p>{{text}}</p>
                {{> evidence this}}
              </li>
              {{/each}}
            </ul>
            {{else}}
            <p>No author questions were supplied.</p>
            {{/if}}
          </section>

          <section id="recommendation">
            <h2>Review Recommendation</h2>
            <div class="callout">
              <p>
                <strong>{{review.recommendation.decision}}.</strong>
                {{review.recommendation.summary.text}}
              </p>
            </div>
            {{> evidence review.recommendation.summary}}

            {{#if review.recommendation.blockers}}
            <div class="risk-table">
              {{#each review.recommendation.blockers}}
              <div class="risk-row">
                <strong><span class="tag warn">Blocker</span></strong>
                {{> evidence this}}
                <p>{{text}}</p>
              </div>
              {{/each}}
            </div>
            {{/if}}

            {{#if review.recommendation.follow_ups}}
            <div class="risk-table">
              {{#each review.recommendation.follow_ups}}
              <div class="risk-row">
                <strong><span class="tag">Follow-up</span></strong>
                {{> evidence this}}
                <p>{{text}}</p>
              </div>
              {{/each}}
            </div>
            {{/if}}
          </section>

        </div>
      </main>
    </div>
    <script>
      const menuButton = document.querySelector(".hamburger");
      const drawerScrim = document.querySelector(".drawer-scrim");
      const heroTitle = document.querySelector(".hero h1");
      const stickyTitle = document.querySelector(".sticky-title");
      const setMenuOpen = (isOpen) => {
        document.body.classList.toggle("drawer-open", isOpen);
        menuButton.setAttribute("aria-expanded", String(isOpen));
      };

      menuButton.addEventListener("click", () => {
        setMenuOpen(!document.body.classList.contains("drawer-open"));
      });

      drawerScrim.addEventListener("click", () => {
        setMenuOpen(false);
      });

      document.querySelectorAll("#report-nav a").forEach((link) => {
        link.addEventListener("click", () => {
          setMenuOpen(false);
        });
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") setMenuOpen(false);
      });

      if (heroTitle && stickyTitle) {
        const titleObserver = new IntersectionObserver(([entry]) => {
          const titleIsAboveViewport = !entry.isIntersecting && entry.boundingClientRect.bottom <= 0;
          document.body.classList.toggle("title-stuck", titleIsAboveViewport);
        });
        titleObserver.observe(heroTitle);
      }
    </script>
    <script type="module">
      // Progressive enhancement: highlight evidence blocks with shiki (CDN).
      // On failure (offline, CDN blocked) the plain rendering above remains.
      try {
        const { codeToHtml } = await import("https://esm.sh/shiki@3.0.0");
        const parser = new DOMParser();
        for (const pre of document.querySelectorAll(".code-card pre")) {
          const rows = [...pre.querySelectorAll(".code-line")];
          if (rows.length === 0) continue;
          const code = rows.map((row) => row.querySelector(".src").textContent).join("\n");
          const lang = pre.dataset.lang === "md" ? "markdown" : "typescript";
          const highlighted = await codeToHtml(code, { lang, theme: "vitesse-dark" });
          const lines = parser
            .parseFromString(highlighted, "text/html")
            .querySelectorAll("code .line");
          if (lines.length !== rows.length) continue;
          rows.forEach((row, index) => {
            row.querySelector(".src").innerHTML = lines[index].innerHTML;
          });
          pre.classList.add("is-highlighted");
        }
      } catch {
        /* keep unhighlighted fallback */
      }
    </script>
  </body>
</html>
