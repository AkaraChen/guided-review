{{#each evidence}}
<article class="code-card">
  <header>
    <h3>{{name}}</h3>
    <a href="{{@root.pull_request.url}}/files">{{path}}:{{start_line}}-{{end_line}}</a>
  </header>
  <pre data-lang="{{language}}">{{#each lines}}<span class="code-line"><span class="ln">{{number}}</span><span class="src">{{text}}</span></span>{{/each}}</pre>
</article>
{{/each}}
