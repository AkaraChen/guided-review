<a class="file-link" href="{{@root.pull_request.url}}/files#diff-{{diff_anchor path}}{{#if start_line}}R{{start_line}}{{/if}}" title="{{path}}" target="_blank" rel="noopener noreferrer"><svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="{{file_icon_bg path}}" opacity="0.2"/><path d="{{file_icon_fg path}}"/></svg><span>{{short_path path}}{{#if start_line}}:{{start_line}}-{{end_line}}{{/if}}</span></a>
