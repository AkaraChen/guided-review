    </aside>
    </div>
  </div>
  <div class="page-header__bar" aria-hidden="true">
    <div class="page-header__bar-inner"><span>{{review.title}}</span></div>
  </div>
</page-header>
<script>
  (() => {
    if (customElements.get("page-header")) return;

    class PageHeaderElement extends HTMLElement {
      connectedCallback() {
        if (this.dataset.wired) return;
        this.dataset.wired = "true";

        const observer = new IntersectionObserver(([entry]) => {
          const collapsed = !entry.isIntersecting;
          this.toggleAttribute("collapsed", collapsed);
          document.body.classList.toggle("header-collapsed", collapsed);
        });
        observer.observe(this.querySelector("h1"));

        const smoothScrollTo = (top) => {
          const reducedMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;
          window.scrollTo({ top, behavior: reducedMotion ? "auto" : "smooth" });
        };

        this.querySelector(".page-header__bar").addEventListener("click", () => {
          smoothScrollTo(0);
        });

        /* A flick that stops inside the header region settles smoothly in the
           direction of travel: down lands just past the header (fixed bar
           state), up returns to the top. */
        let lastY = window.scrollY;
        let direction = 1;
        window.addEventListener(
          "scroll",
          () => {
            const y = window.scrollY;
            if (y !== lastY) direction = y > lastY ? 1 : -1;
            lastY = y;
          },
          { passive: true }
        );
        if ("onscrollend" in window) {
          window.addEventListener("scrollend", () => {
            const settleAt = this.offsetHeight - 40;
            const y = window.scrollY;
            if (y <= 0 || y >= settleAt) return;
            smoothScrollTo(direction > 0 ? settleAt : 0);
          });
        }
      }
    }

    customElements.define("page-header", PageHeaderElement);
  })();
</script>
