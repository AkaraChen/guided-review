<style>
  /* The hero block scrolls away with the page; a fixed compact bar shows once
     the title leaves the viewport. The bar is out of flow, so toggling it
     never changes layout — no scroll feedback, no jitter, no motion needed. */
  page-header {
    display: block;
  }

  .page-header__inner {
    width: min(1180px, 100%);
    margin: 0 auto;
    padding: 20px 20px 0;
  }

  /* Expanded state lives on a card like every section below */
  .page-header__card {
    border: 1px solid var(--line);
    border-radius: 16px;
    background: var(--card);
    padding: 28px;
    box-shadow: var(--shadow-hairline);
  }

  page-header h1 {
    flex: 1;
    max-width: 820px;
    margin: 0;
    font-size: clamp(26px, 3.5vw, 40px);
    font-weight: 300;
    line-height: 1.2;
  }

  .page-header__title {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .page-header__recommendation {
    display: inline-flex;
    flex: none;
    margin-top: 7px;
    border-radius: 8px;
    padding: 5px 10px;
    font-size: 13px;
    font-weight: 600;
    line-height: 1.4;
    white-space: nowrap;
  }

  .page-header__bar {
    position: fixed;
    inset: 0 0 auto;
    z-index: 15;
    display: none;
    border-bottom: 1px solid var(--line);
    background: var(--sticky-bg);
    cursor: pointer;
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    backdrop-filter: blur(20px) saturate(140%);
    box-shadow: var(--shadow-toolbar);
  }

  page-header[collapsed] .page-header__bar {
    display: block;
  }

  .page-header__bar-inner {
    display: flex;
    align-items: center;
    width: min(1180px, 100%);
    min-height: 48px;
    margin: 0 auto;
    padding: 0 128px 0 20px;
    font-size: 14px;
    font-weight: 500;
    line-height: 1.35;
  }

  .page-header__bar-inner > span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Facts strip: one Phosphor icon + value per PR fact, scannable left to right */
  page-header .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px 26px;
    padding-top: 20px;
  }

  page-header .fact {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  page-header .fact svg {
    flex: none;
    width: 17px;
    height: 17px;
    color: var(--muted);
  }

  @media (max-width: 860px) {
    /* keep the title clear of the floating hamburger */
    .page-header__card {
      padding-left: 76px;
    }

    .page-header__title {
      width: calc(100% + 48px);
      margin: 28px 0 0 -48px;
    }

    .page-header__bar-inner {
      padding-left: 76px;
    }
  }
</style>
<page-header>
