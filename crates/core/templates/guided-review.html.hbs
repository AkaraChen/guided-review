<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{review.title}}</title>
    <style>
      :root {
        color-scheme: light;
        /* openknowledge design DNA tokens */
        --bg: #fbf9f4;
        --surface: #fcfcfa;
        --card: #ffffff;
        --ink: #1a1a1a;
        --ink-strong: #231f20;
        --muted: #71717a;
        --muted-fill: #f0ece3;
        --line: #e4e3e0;
        --line-strong: #d4d4d0;
        --dot: #ddd9d1;
        --primary: #3784ff;
        --primary-strong: #1b60f5;
        --primary-fill: #1b60f5;
        --warn-fill: #ffefd9;
        --warn-line: #fcdfb6;
        --warn-ink: #9a5b00;
        --ok: #009767;
        --ok-fill: #e2f5ee;
        --risk: #fb2c36;
        --code-bg: #231f20;
        --code-ink: #f0f0ee;
        --sticky-bg: rgb(251 249 244 / 72%);
        --shadow-hairline: 0 1px 2px rgba(15, 23, 42, 0.05);
        --shadow-toolbar: 0 1px 2px rgba(15, 23, 42, 0.04), 0 2px 6px -2px rgba(15, 23, 42, 0.06);
        --shadow-panel: 0 18px 48px -24px rgba(35, 31, 32, 0.18);
        --shadow-window: 0 0 48px -16px rgba(35, 31, 32, 0.18);
        --ease: cubic-bezier(0.4, 0, 0.2, 1);
        --font-sans: "DM Sans", Inter, ui-sans-serif, system-ui, -apple-system,
          BlinkMacSystemFont, "Segoe UI", sans-serif;
        --font-mono: "JetBrains Mono", "SFMono-Regular", "SF Mono", Menlo, Consolas,
          "Liberation Mono", monospace;
      }

      /* Dark palette. Keep the two blocks below identical: one covers the explicit
         "Dark" choice, the other covers "System" (no data-theme) on a dark OS. */
      :root[data-theme="dark"] {
        color-scheme: dark;
        --bg: #171614;
        --surface: #1e1d1b;
        --card: #211f1d;
        --ink: #e6e4df;
        --ink-strong: #f2f1ee;
        --muted: #a3a3ab;
        --muted-fill: #2e2c28;
        --line: #34322e;
        --line-strong: #4a4741;
        --dot: #302e29;
        --primary: #6ea3ff;
        --primary-strong: #8db8ff;
        --primary-fill: #2f6ee5;
        --warn-fill: #382a13;
        --warn-line: #57431f;
        --warn-ink: #f0b45c;
        --ok: #3ecf9a;
        --ok-fill: #14352a;
        --risk: #ff6b6e;
        --code-bg: #1a1918;
        --sticky-bg: rgb(23 22 20 / 72%);
        --shadow-hairline: 0 1px 2px rgba(0, 0, 0, 0.4);
        --shadow-toolbar: 0 1px 2px rgba(0, 0, 0, 0.35), 0 2px 6px -2px rgba(0, 0, 0, 0.4);
        --shadow-panel: 0 18px 48px -24px rgba(0, 0, 0, 0.6);
        --shadow-window: 0 0 48px -16px rgba(0, 0, 0, 0.6);
      }

      @media (prefers-color-scheme: dark) {
        :root:not([data-theme="light"]) {
          color-scheme: dark;
          --bg: #171614;
          --surface: #1e1d1b;
          --card: #211f1d;
          --ink: #e6e4df;
          --ink-strong: #f2f1ee;
          --muted: #a3a3ab;
          --muted-fill: #2e2c28;
          --line: #34322e;
          --line-strong: #4a4741;
          --dot: #302e29;
          --primary: #6ea3ff;
          --primary-strong: #8db8ff;
          --primary-fill: #2f6ee5;
          --warn-fill: #382a13;
          --warn-line: #57431f;
          --warn-ink: #f0b45c;
          --ok: #3ecf9a;
          --ok-fill: #14352a;
          --risk: #ff6b6e;
          --code-bg: #1a1918;
          --sticky-bg: rgb(23 22 20 / 72%);
          --shadow-hairline: 0 1px 2px rgba(0, 0, 0, 0.4);
          --shadow-toolbar: 0 1px 2px rgba(0, 0, 0, 0.35), 0 2px 6px -2px rgba(0, 0, 0, 0.4);
          --shadow-panel: 0 18px 48px -24px rgba(0, 0, 0, 0.6);
          --shadow-window: 0 0 48px -16px rgba(0, 0, 0, 0.6);
        }
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        /* the collapsing header changes document height; anchoring would
           counter-adjust scrollY and oscillate the collapse */
        overflow-anchor: none;
        background-color: var(--bg);
        background-image: radial-gradient(var(--dot) 1px, transparent 1px);
        background-size: 24px 24px;
        color: var(--ink);
        font: 16px/1.55 var(--font-sans);
        -webkit-font-smoothing: antialiased;
      }

      ::selection {
        background: rgba(55, 132, 255, 0.2);
      }

      a {
        color: var(--primary-strong);
        text-decoration-thickness: 1px;
        text-underline-offset: 3px;
      }

      .hamburger,
      .drawer-scrim {
        display: none;
      }

      .page {
        max-width: 1180px;
        margin: 0 auto;
        padding: 12px 20px 72px;
      }

      .back-to-top {
        position: fixed;
        right: 20px;
        bottom: 20px;
        z-index: 15;
        display: grid;
        place-items: center;
        width: 44px;
        height: 44px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: var(--card);
        padding: 0;
        color: var(--ink);
        box-shadow: var(--shadow-toolbar);
        cursor: pointer;
        opacity: 0;
        transform: translateY(8px);
        visibility: hidden;
      }

      .back-to-top svg {
        width: 18px;
        height: 18px;
      }

      .back-to-top:hover {
        box-shadow: var(--shadow-panel);
      }

      .back-to-top:focus-visible {
        outline: 2px solid var(--primary);
        outline-offset: 2px;
      }

      body.header-collapsed .back-to-top {
        opacity: 1;
        transform: translateY(0);
        visibility: visible;
      }

      h1,
      h2,
      h3 {
        line-height: 1.15;
        letter-spacing: -0.025em;
        text-wrap: balance;
      }

      h1 code,
      h2 code {
        font-size: 0.9em;
      }

      h2 {
        margin: 0 0 16px;
        font-size: 20px;
        font-weight: 400;
      }

      /* Section titles pin flush under the fixed title bar while their card
         scrolls: any gap here would sit over the card and leak its content,
         so the layer boundary is the bar's own hairline and shadow. */
      section > h2 {
        position: sticky;
        top: 48px;
        z-index: 2;
        display: flex;
        align-items: center;
        gap: 10px;
        margin: -28px -28px 0;
        padding: 16px 28px;
        container-type: scroll-state;
      }

      /* Background lives on a pseudo so the stuck state can square its top
         corners: mid-card the rounded notches would leak scrolling content. */
      section > h2::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: -1;
        border-radius: 16px 16px 0 0;
        background: var(--card);
        transition: border-radius 150ms var(--ease);
      }

      @container scroll-state(stuck: top) {
        section > h2::before {
          border-radius: 0;
        }
      }

      /* While pinned, a hairline (plus a faint shadow) marks the title as a
         floating layer — the boundary is deliberate instead of hidden. */
      section > h2::after {
        content: "";
        position: absolute;
        right: 0;
        bottom: 0;
        left: 0;
        height: 1px;
        background: var(--line);
        box-shadow: 0 2px 6px -2px rgba(15, 23, 42, 0.12);
        opacity: 0;
        transition: opacity 150ms var(--ease);
      }

      @container scroll-state(stuck: top) {
        section > h2::after {
          opacity: 1;
        }
      }

      section > h2 svg {
        flex: none;
        width: 18px;
        height: 18px;
        color: var(--muted);
      }

      h3 {
        margin: 0 0 8px;
        font-size: 17px;
        font-weight: 500;
        letter-spacing: -0.01em;
      }

      p {
        margin: 0;
      }

      .lede {
        max-width: 720px;
        margin-top: 14px;
        color: var(--muted);
        font-size: 16px;
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        margin: -1px;
        overflow: hidden;
        clip-path: inset(50%);
        white-space: nowrap;
      }

      .diff-add {
        color: var(--ok);
      }

      .diff-del {
        color: var(--risk);
      }

      main {
        display: grid;
        grid-template-columns: 220px minmax(0, 1fr);
        gap: 32px;
        margin-top: 36px;
      }

      nav {
        position: sticky;
        top: 72px;
        align-self: start;
        padding: 6px 0;
      }

      nav a {
        display: block;
        border-radius: 999px;
        padding: 8px 14px;
        color: var(--muted);
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        transition: color 150ms var(--ease), background-color 150ms var(--ease);
      }

      nav a:hover {
        color: var(--ink);
        background: var(--muted-fill);
      }

      nav a.active {
        color: var(--ink);
        background: var(--muted-fill);
      }

      nav a:focus-visible {
        outline: 2px solid var(--primary);
        outline-offset: 2px;
      }

      .content {
        display: grid;
        gap: 22px;
        min-width: 0;
      }

      section {
        min-width: 0;
        scroll-margin-top: 72px;
        border: 1px solid var(--line);
        border-radius: 16px;
        background: var(--card);
        padding: 28px;
        box-shadow: var(--shadow-hairline);
      }

      .callout {
        border: 1px solid var(--warn-line);
        border-radius: 12px;
        background: var(--warn-fill);
        padding: 20px 22px;
      }

      .grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 18px;
      }

      li {
        color: var(--muted);
      }

      ul,
      ol {
        margin: 10px 0 0;
        padding-left: 22px;
      }

      li + li {
        margin-top: 8px;
      }

      .reading-list {
        counter-reset: step;
        display: grid;
        gap: 14px;
        margin-top: 16px;
      }

      .reading-item {
        display: grid;
        grid-template-columns: 24px minmax(0, 1fr);
        gap: 12px;
        align-items: start;
      }

      .reading-item h3 {
        display: inline-flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 2px 6px;
      }

      .reading-item::before {
        counter-increment: step;
        content: counter(step) ".";
        color: var(--muted);
        font-family: var(--font-mono);
        font-size: 14px;
        /* Match the file-link's first line box (13px text / 16px icon) so the
           number sits on the same visual line as the link. */
        line-height: 20px;
        text-align: right;
      }

      .reading-item > * {
        min-width: 0;
      }

      code {
        border-radius: 6px;
        background: var(--muted-fill);
        padding: 2px 6px;
        color: var(--ink-strong);
        font-family: var(--font-mono);
        font-size: 0.86em;
      }

      .rec-group {
        margin-top: 24px;
      }

      .rec-item {
        margin-top: 14px;
      }

      .rec-item > p {
        color: var(--muted);
      }

      .footer-note {
        color: var(--muted);
        font-size: 14px;
      }

      @media (prefers-reduced-motion: no-preference) {
        .back-to-top {
          transition: opacity 250ms var(--ease), transform 250ms var(--ease),
            visibility 250ms var(--ease), box-shadow 150ms var(--ease);
        }

        section {
          animation: reveal-in 500ms var(--ease) backwards;
        }

        section:nth-child(2) { animation-delay: 60ms; }
        section:nth-child(3) { animation-delay: 120ms; }
        section:nth-child(4) { animation-delay: 180ms; }

        @keyframes reveal-in {
          from {
            opacity: 0;
            transform: translateY(7px);
          }
          to {
            opacity: 1;
            transform: none;
          }
        }
      }

      @media (max-width: 860px) {
        main {
          grid-template-columns: 1fr;
        }

        .hamburger {
          position: fixed;
          top: 16px;
          left: 16px;
          z-index: 35;
          display: inline-flex;
          width: 44px;
          height: 44px;
          flex-direction: column;
          justify-content: center;
          gap: 5px;
          border: 1px solid var(--line);
          border-radius: 999px;
          background: var(--card);
          box-shadow: var(--shadow-panel);
          cursor: pointer;
          transition: transform 150ms var(--ease), box-shadow 150ms var(--ease);
        }

        .hamburger:hover {
          transform: translateY(-2px);
        }

        .hamburger:active {
          transform: scale(0.98);
        }

        .hamburger span {
          display: block;
          width: 18px;
          height: 2px;
          margin: 0 auto;
          border-radius: 999px;
          background: var(--ink);
        }

        .drawer-scrim {
          position: fixed;
          inset: 0;
          z-index: 20;
          border: 0;
          background: rgba(35, 31, 32, 0.35);
          padding: 0;
        }

        body.drawer-open .drawer-scrim {
          display: block;
        }

        main {
          display: block;
        }

        nav {
          position: fixed;
          top: 0;
          bottom: 0;
          left: 0;
          z-index: 30;
          width: min(82vw, 320px);
          border-right: 1px solid var(--line);
          background: var(--card);
          padding: 84px 22px 22px;
          transform: translateX(-105%);
          transition: transform 200ms var(--ease);
          visibility: hidden;
          box-shadow: var(--shadow-window);
        }

        body.drawer-open nav {
          transform: translateX(0);
          visibility: visible;
        }

        nav a {
          padding: 12px 14px;
          font-size: 16px;
        }

      }
    </style>
    {{> component-scripts}}
  </head>
  <body>
    {{> theme-switch}}
    <button
      class="hamburger"
      type="button"
      aria-controls="report-nav"
      aria-expanded="false"
      aria-label="Open report menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
    <button class="drawer-scrim" type="button" aria-label="Close report menu"></button>
    <button class="back-to-top" type="button" aria-label="Back to top" title="Back to top">
      <svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M200,112H56l72-72Z" opacity="0.2"/><path d="M205.66,106.34l-72-72a8,8,0,0,0-11.32,0l-72,72A8,8,0,0,0,56,120h64v96a8,8,0,0,0,16,0V120h64a8,8,0,0,0,5.66-13.66ZM75.31,104,128,51.31,180.69,104Z"/></svg>
    </button>
    {{> page-header}}
    <div class="page">
      <main>
        <nav id="report-nav" aria-label="Report sections">
          <a href="#thesis">Thesis</a>
          <a href="#reading">Reading order</a>
          <a href="#lines">Evidence</a>
          <a href="#verification">Verification</a>
          <a href="#risks">Risks</a>
          <a href="#questions">Questions</a>
          <a href="#recommendation">Recommendation</a>
        </nav>

        <div class="content">
          <section id="thesis">
            <h2><svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M176,128a48,48,0,1,1-48-48A48,48,0,0,1,176,128Z" opacity="0.2"/><path d="M221.87,83.16A104.1,104.1,0,1,1,195.67,49l22.67-22.68a8,8,0,0,1,11.32,11.32l-96,96a8,8,0,0,1-11.32-11.32l27.72-27.72a40,40,0,1,0,17.87,31.09,8,8,0,1,1,16-.9,56,56,0,1,1-22.38-41.65L184.3,60.39a87.88,87.88,0,1,0,23.13,29.67,8,8,0,0,1,14.44-6.9Z"/></svg>Thesis</h2>
            <p>{{review.thesis.text}}</p>
            {{> evidence review.thesis}}
          </section>

          <section id="reading">
            <h2><svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M216,64V192H104V64Z" opacity="0.2"/><path d="M224,128a8,8,0,0,1-8,8H104a8,8,0,0,1,0-16H216A8,8,0,0,1,224,128ZM104,72H216a8,8,0,0,0,0-16H104a8,8,0,0,0,0,16ZM216,184H104a8,8,0,0,0,0,16H216a8,8,0,0,0,0-16ZM43.58,55.16,48,52.94V104a8,8,0,0,0,16,0V40a8,8,0,0,0-11.58-7.16l-16,8a8,8,0,0,0,7.16,14.32ZM79.77,156.72a23.73,23.73,0,0,0-9.6-15.95,24.86,24.86,0,0,0-34.11,4.7,23.63,23.63,0,0,0-3.57,6.46,8,8,0,1,0,15,5.47,7.84,7.84,0,0,1,1.18-2.13,8.76,8.76,0,0,1,12-1.59A7.91,7.91,0,0,1,63.93,159a7.64,7.64,0,0,1-1.57,5.78,1,1,0,0,0-.08.11L33.59,203.21A8,8,0,0,0,40,216H72a8,8,0,0,0,0-16H56l19.08-25.53A23.47,23.47,0,0,0,79.77,156.72Z"/></svg>Suggested Reading Order</h2>
            <div class="reading-list">
              {{#each review.reading_order}}
              <div class="reading-item">
                <div>
                  <h3>
                    {{#each path}}{{> file-link path=this start_line=null end_line=null}}{{/each}}
                  </h3>
                  <p>{{reason.text}}</p>
                </div>
              </div>
              {{/each}}
            </div>
          </section>

          <section id="lines">
            <h2><svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M192,112a80,80,0,1,1-80-80A80,80,0,0,1,192,112Z" opacity="0.2"/><path d="M229.66,218.34,179.6,168.28a88.21,88.21,0,1,0-11.32,11.31l50.06,50.07a8,8,0,0,0,11.32-11.32ZM40,112a72,72,0,1,1,72,72A72.08,72.08,0,0,1,40,112Z"/></svg>Evidence Walkthrough</h2>
            <div class="grid">
              {{#each review.line_map}}
              {{> claim-card index=@index badge=line basis=claim.basis warn=false title=title summary=claim.text show_evidence=true claim=claim}}
              {{/each}}
            </div>
          </section>

          <section id="verification">
